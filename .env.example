# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Telegram bot token from @BotFather (e.g. 123456789:AA...). Leave blank to
# disable the Telegram integration. Keep this SECRET — never commit it.
TELEGRAM_BOT_TOKEN=

# Optional: a SEPARATE bot token used only when JOURNEY_ENV=test, so the test
# server never hijacks your real bot (Telegram allows only one poller per bot).
# Leave blank to keep Telegram disabled in tests.
TELEGRAM_TEST_BOT_TOKEN=
